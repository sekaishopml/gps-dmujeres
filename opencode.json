{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-vibeguard",
    "opencode-type-inject",
    "opencode-notificator",
    "opencode-dynamic-context-pruning",
    "opencode-shell-strategy",
    "opencode-firecrawl"
  ],
  "mcp": {
    "redis": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-redis"],
      "environment": {
        "REDIS_URL": "redis://localhost:6379"
      },
      "enabled": true
    },
    "postgres": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://dmt_admin:dmt_prod_secure_2026_change_me@localhost:5433/dmtracker"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "description": "Automatización de navegador web: navegar, hacer clic, capturar errores de consola, tomar screenshots",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "github": {
      "type": "local",
      "description": "Gestión de repo: PRs, issues, código, commits",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "description": "Razonamiento paso a paso para resolver problemas complejos",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "description": "Operaciones avanzadas de archivos: leer, escribir, buscar, metadata",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/gps-dmujeres"
      ],
      "enabled": true
    }
  },
  "lsp": {
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".js", ".ts", ".tsx", ".jsx", ".mjs", ".cjs"]
    },
    "eslint": {
      "command": ["vscode-eslint-language-server", "--stdio"],
      "extensions": [".js", ".ts", ".tsx", ".jsx", ".mjs", ".cjs", ".vue", ".svelte"]
    },
    "pyright": {
      "command": ["pyright-langserver", "--stdio"],
      "extensions": [".py"]
    },
    "svelte": {
      "command": ["svelteserver", "--stdio"],
      "extensions": [".svelte"]
    },
    "bash": {
      "command": ["bash-language-server", "start"],
      "extensions": [".sh", ".bash", ".zsh"]
    },
    "yaml-ls": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    },
    "html": {
      "command": ["vscode-html-language-server", "--stdio"],
      "extensions": [".html"]
    },
    "css": {
      "command": ["vscode-css-language-server", "--stdio"],
      "extensions": [".css"]
    },
    "json": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json"]
    }
  }
}
