# ============================================
# D-MUJERES-TRACCAR Fleet Tracking Platform
# Configuración de Variables de Entorno
# ============================================
# Copia este archivo como .env y ajusta los valores

# Zona horaria (Ecuador continental)
TZ=America/Guayaquil

# ========== PostgreSQL + TimescaleDB ==========
POSTGRES_DB=dmtracker
POSTGRES_USER=dmt_admin
POSTGRES_PASSWORD=cambia_esta_contraseña_segura

# ========== Nivel de Logs ==========
LOG_LEVEL=info

# ========== CORS para la API ==========
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ========== Frontend ==========
VITE_API_URL=http://localhost:8000

# ========== Dominio para SSL (Let's Encrypt) ==========
DOMAIN=tracking.tudominio.com
CERT_EMAIL=admin@tudominio.com